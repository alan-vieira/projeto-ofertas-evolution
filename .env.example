# ============================================================================
# EVOLUTION API (OBRIGATÓRIO)
# ============================================================================
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE_NAME=VendaBot
EVOLUTION_API_KEY=SUA_API_KEY_AQUI

# ============================================================================
# WHATSAPP (OBRIGATÓRIO)
# ============================================================================
# JID do grupo (obter via webhook ou dashboard da Evolution)
# Formato: 120363XXX@g.us
WHATSAPP_GROUP_JID=SEU_JID_AQUI

# Nome do grupo (apenas para referência/logs)
WHATSAPP_GROUP_NAME=Casa, Decor e Afins

# Delay entre envios em segundos (evitar rate limiting/ban)
WHATSAPP_DELAY_BETWEEN_OFFERS_SEC=10

# ============================================================================
# CACHE (OPCIONAL)
# ============================================================================
# Tempo de vida do cache em horas
CACHE_TTL_HOURS=24

# ============================================================================
# LOGGING (OPCIONAL)
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/execucao.log

# ============================================================================
# PATHS (OPCIONAL - usa defaults se não definido)
# ============================================================================
OFFERS_INPUT_FILE=ofertas.txt
OFFERS_LINKS_FILE=config/links.txt
CONFIG_FILE=config/settings.json
MEDIA_DOWNLOAD_FOLDER=images

# ============================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha os valores obrigatórios
# 3. NÃO commit o arquivo .env no Git (já está no .gitignore)
# ============================================================================